#include <iostream>
#include <vector>
#include <string>
#include <fstream>
using namespace std;

vector<string>attendance = {"envy ", "ilyas ", "damon ", "hamir " ,"ajay ", "bode ", "george ", "jordan ", "chris ", "caleb ", "seth ", "ryan ", "tiahna ", "bailin ", "elijah ", "connor "};

int main() {
  int answer;

  for (int i = 0; i < attendance.size(); i++) {
    cout << "Is " << attendance[i] << "here? (1 for yes, 0 for no): ";
    cin >> answer;
    
    if (answer == 1) {
      cout << attendance[i] << "is present.\n\n";
    } else if (answer == 0) {
      cout << attendance[i] << "is absent.\n\n";
    } else {
      cout << "Invalid input. Please enter 1 or 0.\n\n";
    }
  }
  
  return 0;
}

