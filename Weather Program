#include <iostream>
#include <cmath>
using namespace std;
void WindChill(double& temp, double& winspd,double& WindChill_Out);
void CloudBase(double& temp, double& dewpoint, double& CloudBase_Out);
int main()
{
    
    double temp = 0;
    double winspd = 0;
    double dewpoint = 0;
    double WindChill_Out = 0;
    double CloudBase_Out = 0;
cout << "This code will calculate wind chill and wind speed\n";
cout << "Input current temperature\n";
cin >> temp;
cout << "Input wind speed\n";
cin >> winspd;
cout << "Input Dewpoint\n";
cin >> dewpoint;

WindChill(temp,winspd,WindChill_Out);
CloudBase(temp,dewpoint,CloudBase_Out);

    return 0;
}
void WindChill(double& temp, double& winspd,double& WindChill_Out ){ 
    WindChill_Out = 35.74 + 0.621*temp - pow(35.75*winspd, 0.16) +  pow(0.4275*temp*winspd, 0.16);
cout << "The Wind Chill is\n"<< WindChill_Out;
}

void CloudBase(double& temp, double& dewpoint, double& CloudBase_Out)
{CloudBase_Out = 1000*temp-dewpoint/4.4;
    cout << "\nThe Cloud Base is\n" << CloudBase_Out;
}
