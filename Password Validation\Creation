// this code will run a password creation and validation
#include <iostream>
#include <vector>
#include <string>
#include <cctype>
using namespace std;

bool validatePassword(string password)
{
    // Check if password is at least 8 characters
    if (password.length() < 8 || password.length() > 20)
    {
        cout << "Password should be at least 8 characters and less than 20, try again.\n";
        
        cout << "\n\n Password must include \n 1 number \n 1 uppercase letter \n 1 lowercase letter";
        return false;
    }

    bool hasNumber = false;
    bool hasUppercase = false;
    bool hasLowercase = false;

    // Check for number, uppercase, and lowercase
    for (char c : password)
    {
        if (isdigit(c))
            hasNumber = true;
        if (isupper(c))
            hasUppercase = true;
        if (islower(c))
            hasLowercase = true;
    }

    // Provide feedback on what's missing
    if (!hasNumber)
        cout << "Password must contain at least one number.\n";
    if (!hasUppercase)
        cout << "Password must contain at least one uppercase letter.\n";
    if (!hasLowercase)
        cout << "Password must contain at least one lowercase letter.\n";

    // Return true only if all requirements are met
    return (hasNumber && hasUppercase && hasLowercase);
}

int main()
{
    string password;
    string passwordConfirm;
    int attempts = 0;
    const int MAX_ATTEMPTS = 3;

    cout << " -------------------------------- \n";
    cout << " | Password Validation/Creation | \n";
    cout << " -------------------------------- \n";

    cout << "\n\n Please enter a password with at least:\n";
    cout << "\t 8 characters\n";
    cout << "\t One number\n";
    cout << "\t One uppercase letter, and One lowercase letter\n";

    // Get user input for password with 3 attempt limit
    bool validPassword = false;
    while (!validPassword && attempts < MAX_ATTEMPTS)
    {
        cout << "\n\nEnter your password (Attempt " << (attempts + 1) << "/" << MAX_ATTEMPTS << "): ";
        cin >> password;

        if (validatePassword(password))
        {
            validPassword = true;
        }
        else
        {
            attempts++;
            if (attempts < MAX_ATTEMPTS)
            {
                cout << "\nAttempts remaining: " << (MAX_ATTEMPTS - attempts) << "\n";
            }
        }
    }

    // Check if max attempts exceeded
    if (!validPassword)
    {
        cout << "\nMaximum password attempts exceeded. Program terminating.\n";
        return 1;
    }

    // User inputs password again to confirm
    bool passwordsMatch = false;
    while (!passwordsMatch)
    {
        cout << "\nConfirm your password: ";
        cin >> passwordConfirm;

        if (password == passwordConfirm)
        {
            cout << "\nPassword successfully created!\n";
            passwordsMatch = true;
        }
        else
        {
            cout << "Passwords do not match. Please try again.\n";
        }
    }

    return 0;
}
